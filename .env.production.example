# ReminderBot Pro - Production Environment Variables
# Copy this file to .env and fill in the values

# Django/FastAPI Secret Key (generate with: openssl rand -hex 32)
SECRET_KEY=change-me-to-a-random-secret-key

# Database
DATABASE_URL=postgresql+asyncpg://reminderbot:reminderbot_secret@localhost:5432/reminderbot

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Environment
ENVIRONMENT=production
LOG_LEVEL=info
DEBUG=false

# URLs
FRONTEND_URL=https://reminderbot.example.com
CORS_ORIGINS=https://reminderbot.example.com
SERVER_NAME=reminderbot.example.com

# Sentry (Error Tracking)
SENTRY_DSN=

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@reminderbot.example.com
SMTP_PASSWORD=change-me

# Twilio (SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Pushover (Push Notifications)
PUSHOVER_USER_KEY=
PUSHOVER_API_TOKEN=

# Stripe (Payments)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# Frontend
NEXT_PUBLIC_API_URL=https://api.reminderbot.example.com
NEXT_PUBLIC_WS_URL=wss://api.reminderbot.example.com/ws
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_GA_ID=

# PostgreSQL (Docker Compose)
POSTGRES_USER=reminderbot
POSTGRES_PASSWORD=reminderbot_secret
POSTGRES_DB=reminderbot

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Prometheus
PROMETHEUS_PASSWORD=prometheus_secret
